# ---- Build Stage ----
FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_AUTH_BASE_URL=/api/auth
ARG VITE_PATIENT_BASE_URL=/api/patients
ARG VITE_DOCTOR_BASE_URL=/api/doctors
ARG VITE_APPOINTMENT_BASE_URL=/api/appointments
ARG VITE_TELEMEDICINE_BASE_URL=/api/sessions
ARG VITE_SYMPTOM_BASE_URL=/api/symptoms
ARG VITE_PAYMENT_BASE_URL=/api/payments

ENV VITE_AUTH_BASE_URL=$VITE_AUTH_BASE_URL
ENV VITE_PATIENT_BASE_URL=$VITE_PATIENT_BASE_URL
ENV VITE_DOCTOR_BASE_URL=$VITE_DOCTOR_BASE_URL
ENV VITE_APPOINTMENT_BASE_URL=$VITE_APPOINTMENT_BASE_URL
ENV VITE_TELEMEDICINE_BASE_URL=$VITE_TELEMEDICINE_BASE_URL
ENV VITE_SYMPTOM_BASE_URL=$VITE_SYMPTOM_BASE_URL
ENV VITE_PAYMENT_BASE_URL=$VITE_PAYMENT_BASE_URL

COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# ---- Serve Stage ----
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
